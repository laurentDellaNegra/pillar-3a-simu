---

---

<div class="card" style="border-color:#1e3a50">
  <div
    id="etfLabel"
    style="font-size:11px;font-family:var(--m);color:#60a5fa;margin-bottom:12px;letter-spacing:1px"
  >
  </div>
  <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:end">
    <div style="flex:1;min-width:250px">
      <div
        style="font-size:9px;color:#3b82f6;font-family:var(--m);margin-bottom:6px;height:22px;display:flex;align-items:center"
      >
        ETF 1
      </div>
      <select id="idxSel"></select>
    </div>
    <div style="flex:1;min-width:250px">
      <div
        style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;height:22px"
      >
        <div style="font-size:9px;color:#f59e0b;font-family:var(--m)" id="lbETF2">ETF 2</div>
        <div style="display:flex;align-items:center;gap:6px">
          <label class="tog"><input type="checkbox" id="cmpToggle" /><span class="tr"></span></label
          >
          <span id="lbCmpOn" style="font-size:9px;color:#5a7080;font-family:var(--m)"></span>
        </div>
      </div>
      <select id="idxSel2" disabled style="opacity:.4"></select>
    </div>
  </div>
  <div id="idxInfo" class="idx-info"></div>
</div>
