---

---

<div class="card">
  <div
    id="paramLabel"
    style="font-size:11px;font-family:var(--m);color:#3b82f6;margin-bottom:16px;letter-spacing:1px"
  >
  </div>
  <div class="g2">
    <div>
      <div id="s1"></div>
      <div id="s2"></div>
      <div id="s3"></div>
    </div>
    <div>
      <div style="margin-bottom:14px">
        <div
          id="lbEmpType"
          style="font-size:11px;color:#7a8fa5;font-family:var(--m);margin-bottom:8px"
        >
        </div>
        <div class="pills" id="pet"></div>
        <div id="seHint" style="font-size:9px;color:#10b981;font-family:var(--m);margin-top:6px">
        </div>
      </div>
      <div style="margin-bottom:14px">
        <div
          id="lbStatus"
          style="font-size:11px;color:#7a8fa5;font-family:var(--m);margin-bottom:8px"
        >
        </div>
        <div class="pills" id="ps"></div>
      </div>
      <div style="margin-bottom:14px">
        <div
          id="lbCanton"
          style="font-size:11px;color:#7a8fa5;font-family:var(--m);margin-bottom:8px"
        >
        </div>
        <div class="pills" id="pc"></div>
        <div id="cmHint" style="font-size:9px;color:#3a5060;font-family:var(--m);margin-top:6px">
        </div>
        <div style="margin-top:8px">
          <div
            id="lbCustom"
            style="font-size:11px;color:#7a8fa5;font-family:var(--m);margin-bottom:8px"
          >
          </div>
          <div style="display:flex;align-items:center;gap:8px">
            <input type="number" id="customRateInput" min="0" max="45" step="0.1" value="0" />
            <span style="font-size:11px;color:#5a7080;font-family:var(--m)">%</span>
            <span id="customHint" style="font-size:9px;color:#3a5060;font-family:var(--m)"></span>
          </div>
        </div>
      </div>
      <div style="margin-bottom:14px">
        <div id="lbDed" style="font-size:11px;color:#7a8fa5;font-family:var(--m);margin-bottom:8px">
        </div>
        <div class="pills" id="pdm"></div>
      </div>
      <div
        id="ti"
        style="background:#080c12;border-radius:8px;padding:10px 12px;font-size:10px;font-family:var(--m);color:#4a6070;line-height:1.8"
      >
      </div>
    </div>
  </div>
</div>
